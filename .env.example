APP_NAME=Veltro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=veltro
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
# Public disk serves uploaded images (team/tournament logos, avatars) via
# APP_URL/storage. Requires `php artisan storage:link`. Use `s3` for S3/R2.
# Do NOT use `local` — it is a private disk and images will not be reachable.
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

# Reverb (WebSockets). In production these are provided by Laravel Cloud.
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Use `log` for local development (emails are written to storage/logs/laravel.log).
# In production set MAIL_MAILER=resend and provide RESEND_API_KEY (Laravel Cloud's
# managed email is Resend-backed and can inject the key once the domain is verified).
# The MAIL_FROM_ADDRESS domain must match the verified Resend sending domain.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@veltro.uy"
MAIL_FROM_NAME="${APP_NAME}"

# Resend API key (https://resend.com/api-keys). Required when MAIL_MAILER=resend.
RESEND_API_KEY=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Configuración de hashing de contraseñas
HASH_DRIVER=argon2id

# Opciones de Argon2id ajustables según seguridad y rendimiento
ARGON2ID_MEMORY=65536
ARGON2ID_THREADS=1
ARGON2ID_TIME=4
